{
  "version": 2,
  "public": true,
  "env": [
    "SUPABASE_URL",
    "SUPABASE_SERVICE_ROLE_KEY",
    "SUPABASE_ANON_KEY",
    "SUPABASE_STORAGE_BUCKET",
    "CLIENT_URL"
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/[...all].js" },
    { "source": "/", "destination": "/frontend/index.html" },
    { "source": "/login.html", "destination": "/frontend/login.html" },
    { "source": "/register.html", "destination": "/frontend/register.html" },
    { "source": "/dashboard.html", "destination": "/frontend/dashboard.html" },
    { "source": "/analyzer.html", "destination": "/frontend/analyzer.html" },
    { "source": "/report.html", "destination": "/frontend/report.html" },
    { "source": "/style.css", "destination": "/frontend/style.css" },
    { "source": "/script.js", "destination": "/frontend/script.js" }
  ]
}
